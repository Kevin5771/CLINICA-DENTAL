@page
@model ClinicaDental.Web.Pages.Ventas.CreateModel
@{
    ViewData["Title"] = "Registrar venta";
}

<div class="space-y-6">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">Registrar venta de servicio</h1>
            <p class="mt-1 max-w-3xl text-sm text-slate-500">Asocia la venta a un paciente, personal responsable, categoría de servicio, precio, estado y método de pago.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
            <a asp-page="/CategoriasServicios/Index" class="inline-flex items-center justify-center rounded-2xl border border-clinic-200 bg-clinic-50 px-4 py-2.5 text-sm font-semibold text-clinic-700 transition hover:bg-clinic-100">Gestionar servicios</a>
            <a asp-page="/Ventas/Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Volver a ventas</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@Model.Message</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
    }

    <section class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
        <form method="post" class="space-y-6">
            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="Input.NumeroComprobante" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.NumeroComprobante" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Opcional. Se genera si queda vacío" />
                    <span asp-validation-for="Input.NumeroComprobante" class="mt-2 block text-sm text-red-600"></span>
                </div>
                <div>
                    <label asp-for="Input.FechaVenta" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.FechaVenta" type="datetime-local" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.FechaVenta" class="mt-2 block text-sm text-red-600"></span>
                </div>
                <div>
                    <label asp-for="Input.Precio" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.Precio" id="precioVenta" type="number" step="0.01" min="0.01" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.Precio" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="Input.IdPaciente" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdPaciente" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione un paciente</option>
                        @foreach (var paciente in Model.Pacientes)
                        {
                            <option value="@paciente.IdPaciente">@paciente.NombreCompleto</option>
                        }
                    </select>
                    <span asp-validation-for="Input.IdPaciente" class="mt-2 block text-sm text-red-600"></span>
                </div>
                <div>
                    <label asp-for="Input.IdUsuarioResponsable" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdUsuarioResponsable" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione personal</option>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <option value="@usuario.IdUsuario">@usuario.NombreCompleto</option>
                        }
                    </select>
                    <span asp-validation-for="Input.IdUsuarioResponsable" class="mt-2 block text-sm text-red-600"></span>
                </div>
                <div>
                    <label asp-for="Input.IdCategoriaServicio" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdCategoriaServicio" id="categoriaServicio" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione servicio</option>
                        @foreach (var categoria in Model.Categorias)
                        {
                            <option value="@categoria.IdCategoriaServicio" data-precio="@categoria.PrecioBase.ToString(System.Globalization.CultureInfo.InvariantCulture)">@categoria.CodigoCategoria - @categoria.Nombre | Q @categoria.PrecioBase.ToString("0.00")</option>
                        }
                    </select>
                    <span asp-validation-for="Input.IdCategoriaServicio" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Input.IdEstadoVenta" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdEstadoVenta" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Usar estado por defecto</option>
                        @foreach (var estado in Model.Estados)
                        {
                            <option value="@estado.IdEstadoVenta">@estado.Nombre</option>
                        }
                    </select>
                </div>
                <div>
                    <label asp-for="Input.IdMetodoPago" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdMetodoPago" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Usar método por defecto</option>
                        @foreach (var metodo in Model.MetodosPago)
                        {
                            <option value="@metodo.IdMetodoPago">@metodo.Nombre</option>
                        }
                    </select>
                </div>
            </div>

            <div>
                <label asp-for="Input.Descripcion" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                <textarea asp-for="Input.Descripcion" rows="4" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Detalle breve del servicio realizado"></textarea>
                <span asp-validation-for="Input.Descripcion" class="mt-2 block text-sm text-red-600"></span>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-clinic-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-clinic-700">Guardar venta</button>
                <a asp-page="/Ventas/Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Cancelar</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        const categoria = document.getElementById('categoriaServicio');
        const precio = document.getElementById('precioVenta');
        if (categoria && precio) {
            categoria.addEventListener('change', function () {
                const selected = categoria.options[categoria.selectedIndex];
                const precioBase = selected?.dataset?.precio;
                if (precioBase && (!precio.value || Number(precio.value) <= 0)) {
                    precio.value = precioBase;
                }
            });
        }
    </script>
}
