@page
@model ClinicaDental.Web.Pages.Inventario.CreateModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Registrar producto";
}

<div class="space-y-6">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">Registrar producto</h1>
            <p class="text-sm text-slate-500">
                Registra el producto como catálogo. La cantidad disponible se cargará después desde Compras / Entrada de inventario.
            </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
            <a asp-page="/Inventario/Compras"
               class="inline-flex items-center justify-center rounded-2xl bg-clinic-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-clinic-700">
                Ir a compras / entradas
            </a>

            <a asp-page="/Inventario/Index"
               class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                Volver al inventario
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            @Model.Message
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All"
             class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        </div>
    }

    <div class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
        <form method="post" class="space-y-6">
            <div class="grid gap-5 md:grid-cols-3">
                <div>
                    <label asp-for="Input.CodigoProducto" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.CodigoProducto"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="Ejemplo: PROD-001" />
                    <p class="mt-1 text-xs text-slate-500">Opcional. Si lo dejas vacío se genera automáticamente.</p>
                    <span asp-validation-for="Input.CodigoProducto" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Nombre" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.Nombre"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="Ejemplo: Guantes de nitrilo" />
                    <span asp-validation-for="Input.Nombre" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.IdProveedor" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdProveedor"
                            asp-items="@(new SelectList(Model.Proveedores, "IdProveedor", "Nombre"))"
                            class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione un proveedor</option>
                    </select>
                    <span asp-validation-for="Input.IdProveedor" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="Input.UnidadMedida" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.UnidadMedida"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="unidad, caja, frasco, ml" />
                    <span asp-validation-for="Input.UnidadMedida" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.StockMinimo" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.StockMinimo" type="number" step="0.01" min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <p class="mt-1 text-xs text-slate-500">El producto inicia con stock 0. La existencia se suma desde Compras / Entrada.</p>
                    <span asp-validation-for="Input.StockMinimo" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-3">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <label class="flex cursor-pointer items-center gap-3 text-sm font-semibold text-slate-700">
                        <input asp-for="Input.EsPerecedero" class="h-4 w-4 rounded border-slate-300 text-clinic-600 focus:ring-clinic-500" />
                        @Html.DisplayNameFor(m => m.Input.EsPerecedero)
                    </label>
                    <p class="mt-1 text-xs text-slate-500">Marca esta opción cuando el producto tenga vencimiento.</p>
                </div>

                <div>
                    <label asp-for="Input.FechaVencimiento" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.FechaVencimiento" type="date"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.FechaVencimiento" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.CostoUnitario" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.CostoUnitario" type="number" step="0.01" min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.CostoUnitario" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="Input.PrecioVenta" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.PrecioVenta" type="number" step="0.01" min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.PrecioVenta" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Descripcion" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <textarea asp-for="Input.Descripcion" rows="3"
                              class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                              placeholder="Detalle adicional del producto"></textarea>
                    <span asp-validation-for="Input.Descripcion" class="mt-2 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit"
                        class="inline-flex items-center justify-center rounded-2xl bg-clinic-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-clinic-700">
                    Guardar producto base
                </button>

                <a asp-page="/Inventario/Compras"
                   class="inline-flex items-center justify-center rounded-2xl border border-clinic-200 bg-clinic-50 px-5 py-3 text-sm font-semibold text-clinic-700 transition hover:bg-clinic-100">
                    Registrar compra / entrada
                </a>

                <a asp-page="/Inventario/Index"
                   class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>
