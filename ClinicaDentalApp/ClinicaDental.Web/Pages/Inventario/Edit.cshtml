@page "{id:int}"
@model ClinicaDental.Web.Pages.Inventario.EditModel
@{
    ViewData["Title"] = "Editar producto";
}

<div class="space-y-8">
    <section class="rounded-3xl bg-gradient-to-r from-clinic-800 to-cyan-600 p-8 text-white shadow-soft">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-wide text-cyan-100">RF-12</p>
                <h1 class="mt-2 text-3xl font-bold">Actualizar producto</h1>
                <p class="mt-2 max-w-3xl text-sm text-cyan-50">
                    Modifica los datos del producto, proveedor, cantidad disponible, fecha de vencimiento, costo, precio y estado activo.
                </p>
            </div>

            <a asp-page="/Inventario/Index"
               class="inline-flex items-center justify-center rounded-2xl bg-white/15 px-5 py-3 text-sm font-semibold text-white ring-1 ring-white/30 transition hover:bg-white/25">
                Volver al inventario
            </a>
        </div>
    </section>

    <section class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="mb-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
                @Model.Message
            </div>
        }

        <form method="post" class="space-y-6">
            <input type="hidden" asp-for="Input.IdProducto" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
            }

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="Input.CodigoProducto" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.CodigoProducto"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="Ejemplo: PROD-001" />
                    <span asp-validation-for="Input.CodigoProducto" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Nombre" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.Nombre"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="Nombre del producto" />
                    <span asp-validation-for="Input.Nombre" class="mt-1 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="Input.IdProveedor" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdProveedor"
                            class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione proveedor</option>
                        @foreach (var proveedor in Model.Proveedores)
                        {
                            <option value="@proveedor.IdProveedor">@proveedor.Nombre</option>
                        }
                    </select>
                    <span asp-validation-for="Input.IdProveedor" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.CantidadDisponible" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.CantidadDisponible"
                           type="number"
                           step="0.01"
                           min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <p class="mt-1 text-xs text-slate-500">Si cambias la cantidad, se registrará automáticamente un ajuste en movimientos de inventario.</p>
                    <span asp-validation-for="Input.CantidadDisponible" class="mt-1 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-3">
                <div>
                    <label asp-for="Input.StockMinimo" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.StockMinimo"
                           type="number"
                           step="0.01"
                           min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.StockMinimo" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.UnidadMedida" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.UnidadMedida"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                           placeholder="unidad, caja, frasco..." />
                    <span asp-validation-for="Input.UnidadMedida" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div class="flex items-end">
                    <label class="flex w-full cursor-pointer items-center justify-between rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700">
                        <span>Producto activo</span>
                        <input asp-for="Input.Activo" class="h-5 w-5 rounded border-slate-300 text-clinic-600 focus:ring-clinic-500" />
                    </label>
                </div>
            </div>

            <div class="grid gap-5 md:grid-cols-3">
                <div>
                    <label asp-for="Input.CostoUnitario" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.CostoUnitario"
                           type="number"
                           step="0.01"
                           min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.CostoUnitario" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.PrecioVenta" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.PrecioVenta"
                           type="number"
                           step="0.01"
                           min="0"
                           class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <span asp-validation-for="Input.PrecioVenta" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div class="flex items-end">
                    <label class="flex w-full cursor-pointer items-center justify-between rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700">
                        <span>Producto perecedero</span>
                        <input asp-for="Input.EsPerecedero" class="h-5 w-5 rounded border-slate-300 text-clinic-600 focus:ring-clinic-500" />
                    </label>
                </div>
            </div>

            <div>
                <label asp-for="Input.FechaVencimiento" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Input.FechaVencimiento"
                       type="date"
                       class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                <p class="mt-1 text-xs text-slate-500">Obligatoria solo cuando el producto es perecedero.</p>
                <span asp-validation-for="Input.FechaVencimiento" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Input.Descripcion" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                <textarea asp-for="Input.Descripcion"
                          rows="4"
                          class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100"
                          placeholder="Descripción opcional del producto"></textarea>
                <span asp-validation-for="Input.Descripcion" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
                <a asp-page="/Inventario/Index"
                   class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Cancelar
                </a>

                <button type="submit"
                        class="inline-flex items-center justify-center rounded-2xl bg-clinic-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-clinic-800">
                    Guardar cambios
                </button>
            </div>
        </form>
    </section>
</div>

