@page
@model ClinicaDental.Web.Pages.Inventario.MovimientosModel
@{
    ViewData["Title"] = "Movimientos de inventario";
}

<div class="space-y-6">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">Movimientos de inventario</h1>
            <p class="mt-1 max-w-3xl text-sm text-slate-500">
                Registra entradas, salidas y ajustes. Cada movimiento queda asociado al usuario autenticado: <strong>@Model.UsuarioActual</strong>.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <a asp-page="/Inventario/Create" class="inline-flex items-center justify-center rounded-2xl border border-clinic-200 bg-clinic-50 px-4 py-2.5 text-sm font-semibold text-clinic-700 transition hover:bg-clinic-100">+ Nuevo producto</a>
            <a asp-page="/Inventario/Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Ver inventario</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@successMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@Model.Message</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
    }

    <section class="grid gap-6 xl:grid-cols-12">
        <div class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-slate-200 xl:col-span-5">
            <h2 class="text-lg font-bold text-slate-900">Registrar movimiento</h2>
            <p class="mt-1 text-sm text-slate-500">Para salidas, el sistema valida que no se retire más de lo disponible.</p>

            <form method="post" class="mt-6 space-y-5">
                <div>
                    <label for="buscarProductoMovimiento" class="mb-2 block text-sm font-semibold text-slate-700">Buscar producto</label>
                    <input id="buscarProductoMovimiento" type="text" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Escribe nombre, código o proveedor" />
                </div>

                <div>
                    <label asp-for="Input.IdProducto" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.IdProducto" id="productoSelectMovimiento" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione un producto</option>
                        @foreach (var producto in Model.Productos)
                        {
                            <option value="@producto.IdProducto" data-search="@($"{producto.CodigoProducto} {producto.Nombre} {producto.Proveedor}".ToLowerInvariant())">
                                @producto.CodigoProducto - @producto.Nombre | Stock: @producto.CantidadDisponible.ToString("0.##") @producto.UnidadMedida
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Input.IdProducto" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div class="grid gap-5 sm:grid-cols-2">
                    <div>
                        <label asp-for="Input.TipoMovimiento" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                        <select asp-for="Input.TipoMovimiento" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                            <option value="">Seleccione</option>
                            @foreach (var tipo in Model.TiposMovimiento)
                            {
                                <option value="@tipo.Nombre">@tipo.Nombre</option>
                            }
                        </select>
                        <span asp-validation-for="Input.TipoMovimiento" class="mt-2 block text-sm text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Cantidad" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                        <input asp-for="Input.Cantidad" type="number" step="0.01" min="0.01" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                        <span asp-validation-for="Input.Cantidad" class="mt-2 block text-sm text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 sm:grid-cols-2">
                    <div>
                        <label asp-for="Input.FechaMovimiento" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                        <input asp-for="Input.FechaMovimiento" type="datetime-local" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                        <span asp-validation-for="Input.FechaMovimiento" class="mt-2 block text-sm text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Input.CostoUnitario" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                        <input asp-for="Input.CostoUnitario" type="number" step="0.01" min="0" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                        <span asp-validation-for="Input.CostoUnitario" class="mt-2 block text-sm text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Input.Motivo" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <select asp-for="Input.Motivo" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Seleccione un motivo</option>
                        <option value="Compra">Compra</option>
                        <option value="Consumo clínico">Consumo clínico</option>
                        <option value="Ajuste">Ajuste</option>
                        <option value="Pérdida">Pérdida</option>
                        <option value="Vencimiento">Vencimiento</option>
                        <option value="Retiro administrativo">Retiro administrativo</option>
                    </select>
                    <span asp-validation-for="Input.Motivo" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Referencia" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <input asp-for="Input.Referencia" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Factura, compra, documento, retiro, etc." />
                    <span asp-validation-for="Input.Referencia" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Observaciones" class="mb-2 block text-sm font-semibold text-slate-700"></label>
                    <textarea asp-for="Input.Observaciones" rows="3" class="block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-800 outline-none transition focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Detalle opcional del movimiento"></textarea>
                    <span asp-validation-for="Input.Observaciones" class="mt-2 block text-sm text-red-600"></span>
                </div>

                <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-clinic-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-clinic-700">Guardar movimiento</button>
            </form>
        </div>

        <div class="rounded-3xl bg-white shadow-soft ring-1 ring-slate-200 xl:col-span-7">
            <div class="border-b border-slate-100 px-6 py-4">
                <h2 class="text-lg font-bold text-slate-900">Historial de movimientos</h2>
                <p class="mt-1 text-sm text-slate-500">Consulta entradas, salidas y ajustes por producto, fecha o tipo.</p>
            </div>

            <form method="get" class="border-b border-slate-100 px-6 py-4">
                <div class="grid gap-3 lg:grid-cols-5">
                    <input asp-for="Texto" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" placeholder="Buscar" />
                    <select asp-for="IdProducto" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Producto</option>
                        @foreach (var producto in Model.Productos)
                        {
                            <option value="@producto.IdProducto">@producto.Nombre</option>
                        }
                    </select>
                    <select asp-for="TipoMovimiento" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100">
                        <option value="">Tipo</option>
                        @foreach (var tipo in Model.TiposMovimiento)
                        {
                            <option value="@tipo.Nombre">@tipo.Nombre</option>
                        }
                    </select>
                    <input asp-for="FechaDesde" type="date" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                    <input asp-for="FechaHasta" type="date" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-clinic-500 focus:ring-4 focus:ring-clinic-100" />
                </div>
                <div class="mt-3 flex gap-3">
                    <button type="submit" class="rounded-2xl border border-clinic-200 bg-clinic-50 px-5 py-3 text-sm font-semibold text-clinic-700 hover:bg-clinic-100">Filtrar</button>
                    <a asp-page="/Inventario/Movimientos" class="rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Limpiar</a>
                </div>
            </form>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Fecha</th>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Producto</th>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Tipo</th>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Motivo</th>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Cantidad</th>
                            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500">Responsable</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @if (Model.Movimientos.Count == 0)
                        {
                            <tr><td colspan="6" class="px-6 py-10 text-center text-sm text-slate-500">No hay movimientos registrados con los filtros aplicados.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Movimientos)
                            {
                                var tipoClass = item.TipoMovimiento.Contains("Salida") || item.TipoMovimiento.Contains("Negativo")
                                    ? "bg-red-50 text-red-700 ring-red-100"
                                    : "bg-emerald-50 text-emerald-700 ring-emerald-100";
                                <tr class="hover:bg-slate-50">
                                    <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700">@item.FechaMovimiento.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="px-6 py-4"><p class="text-sm font-semibold text-slate-900">@item.Producto</p><p class="text-xs text-slate-500">@item.CodigoProducto</p></td>
                                    <td class="px-6 py-4"><span class="inline-flex rounded-full px-3 py-1 text-xs font-bold ring-1 @tipoClass">@item.TipoMovimiento</span></td>
                                    <td class="px-6 py-4 text-sm text-slate-700">@(string.IsNullOrWhiteSpace(item.Motivo) ? "Sin motivo" : item.Motivo)<p class="text-xs text-slate-500">@item.Referencia</p></td>
                                    <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900">@item.Cantidad.ToString("0.##")</td>
                                    <td class="px-6 py-4 text-sm text-slate-700">@item.Usuario</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const buscadorMovimiento = document.getElementById('buscarProductoMovimiento');
        const selectMovimiento = document.getElementById('productoSelectMovimiento');
        if (buscadorMovimiento && selectMovimiento) {
            buscadorMovimiento.addEventListener('input', function () {
                const texto = this.value.toLowerCase().trim();
                Array.from(selectMovimiento.options).forEach(function (option, index) {
                    if (index === 0) return;
                    const contenido = option.dataset.search || option.textContent.toLowerCase();
                    option.hidden = texto.length > 0 && !contenido.includes(texto);
                });
            });
        }
    </script>
}
