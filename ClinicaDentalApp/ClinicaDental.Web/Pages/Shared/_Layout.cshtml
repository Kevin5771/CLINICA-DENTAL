@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var nombreCompleto = HttpContextAccessor.HttpContext?.Session.GetString("NombreCompleto");
    var usuario = HttpContextAccessor.HttpContext?.Session.GetString("Usuario");
    var rol = HttpContextAccessor.HttpContext?.Session.GetString("Rol");
    var estaLogueado = !string.IsNullOrWhiteSpace(HttpContextAccessor.HttpContext?.Session.GetString("JWToken"));

    var nombreMostrar = !string.IsNullOrWhiteSpace(nombreCompleto)
        ? nombreCompleto
        : (!string.IsNullOrWhiteSpace(usuario) ? usuario : "Usuario");

    var inicial = !string.IsNullOrWhiteSpace(nombreMostrar)
        ? nombreMostrar.Substring(0, 1).ToUpper()
        : "U";

    var fullWidth = (ViewData["FullWidth"] as bool?) == true;
    var currentPath = Context.Request.Path.Value ?? "/";

    var navItems = new[]
    {
        new { Page = "/Index", Match = "/", Icon = "layout-dashboard", Label = "Dashboard", Description = "Vista general" },
        new { Page = "/Pacientes/Index", Match = "/Pacientes", Icon = "users", Label = "Pacientes", Description = "Expedientes" },
        new { Page = "/Citas/Index", Match = "/Citas", Icon = "calendar-days", Label = "Citas", Description = "Agenda clínica" },
        new { Page = "/Calendario/Index", Match = "/Calendario", Icon = "calendar-clock", Label = "Calendario", Description = "Vista de citas" },
        new { Page = "/Inventario/Index", Match = "/Inventario", Icon = "package", Label = "Inventario", Description = "Stock y compras" },
        new { Page = "/Ventas/Index", Match = "/Ventas", Icon = "credit-card", Label = "Ventas", Description = "Transacciones" },
        new { Page = "/CategoriasServicios/Index", Match = "/CategoriasServicios", Icon = "clipboard-list", Label = "Servicios", Description = "Catálogo" },
        new { Page = "/Reportes/Index", Match = "/Reportes", Icon = "bar-chart-3", Label = "Reportes", Description = "Análisis" }
    };
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Clínica Dental</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        clinic: {
                            50: "#effcfb",
                            100: "#d8f6f3",
                            200: "#b3ece7",
                            300: "#7eddd7",
                            400: "#46c7c3",
                            500: "#24aba8",
                            600: "#198887",
                            700: "#176d6d",
                            800: "#175759",
                            900: "#17494a"
                        }
                    },
                    boxShadow: {
                        soft: "0 20px 45px rgba(15, 23, 42, 0.10)",
                        glow: "0 18px 50px rgba(25, 136, 135, 0.18)"
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen app-surface text-slate-800">
    @if (estaLogueado)
    {
        <div class="min-h-screen lg:grid lg:grid-cols-[18rem_1fr]">
            <aside class="no-print fixed inset-y-0 left-0 z-40 hidden w-72 border-r border-slate-200 bg-white/90 px-4 py-5 shadow-soft backdrop-blur-xl lg:flex lg:flex-col">
                <a asp-page="/Index" class="mb-6 flex items-center gap-3 rounded-3xl bg-gradient-to-br from-clinic-50 to-cyan-50 p-3 ring-1 ring-clinic-100 transition hover:shadow-glow">
                    <div class="brand-icon flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-clinic-700 shadow-sm ring-1 ring-clinic-100">
                        <img src="~/favicon.svg" alt="Clínica Dental" class="h-7 w-7 object-contain" />
                    </div>
                    <div>
                        <p class="text-lg font-extrabold leading-5 text-slate-950">Clínica Dental</p>
                        <p class="text-xs font-medium text-clinic-700">Gestión clínica</p>
                    </div>
                </a>

                <nav class="soft-scrollbar flex-1 space-y-1 overflow-y-auto pr-1">
                    @foreach (var item in navItems)
                    {
                        var isActive = item.Match == "/"
                            ? (currentPath == "/" || currentPath.Equals("/Index", StringComparison.OrdinalIgnoreCase))
                            : currentPath.StartsWith(item.Match, StringComparison.OrdinalIgnoreCase);

                        <a asp-page="@item.Page"
                           class="@(isActive ? "nav-active" : "text-slate-600 hover:bg-slate-100 hover:text-slate-950") group flex items-center gap-3 rounded-2xl px-3 py-3 text-sm font-semibold transition">
                            <span class="nav-icon-tile flex h-10 w-10 items-center justify-center rounded-xl bg-white text-clinic-700 shadow-sm ring-1 ring-slate-100 transition group-hover:scale-105">
                                <i data-lucide="@item.Icon" class="h-5 w-5"></i>
                            </span>
                            <span>
                                <span class="block leading-5">@item.Label</span>
                                <span class="block text-xs font-medium opacity-70">@item.Description</span>
                            </span>
                        </a>
                    }
                </nav>

                <div class="mt-5 rounded-3xl border border-slate-200 bg-slate-50 p-3">
                    <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-clinic-100 text-sm font-extrabold text-clinic-700">
                            @inicial
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-bold text-slate-900">@nombreMostrar</p>
                            <p class="truncate text-xs text-slate-500">@(string.IsNullOrWhiteSpace(rol) ? "En línea" : rol)</p>
                        </div>
                    </div>
                    <form method="post" asp-page="/Auth/Logout" class="mt-3">
                        <button type="submit"
                                class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-white px-4 py-2.5 text-sm font-bold text-red-600 ring-1 ring-red-100 transition hover:bg-red-50">
                            <i data-lucide="log-out" class="h-4 w-4"></i>
                            Cerrar sesión
                        </button>
                    </form>
                </div>
            </aside>

            <div class="lg:col-start-2">
                <header class="no-print sticky top-0 z-30 border-b border-slate-200 bg-white/80 backdrop-blur-xl">
                    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
                        <div class="flex items-center gap-3 lg:hidden">
                            <a asp-page="/Index" class="brand-icon flex h-11 w-11 items-center justify-center rounded-2xl bg-clinic-100 text-clinic-700 shadow-sm ring-1 ring-clinic-200">
                                <img src="~/favicon.svg" alt="Clínica Dental" class="h-7 w-7 object-contain" />
                            </a>
                            <div>
                                <p class="text-base font-extrabold leading-5 text-slate-950">Clínica Dental</p>
                                <p class="text-xs text-slate-500">Sistema de gestión</p>
                            </div>
                        </div>

                        <div class="hidden lg:block">
                            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-clinic-700">Panel administrativo</p>
                            <h1 class="text-xl font-extrabold text-slate-950">@ViewData["Title"]</h1>
                        </div>

                        <div class="flex items-center gap-3">
                            <details class="relative lg:hidden">
                                <summary class="flex cursor-pointer list-none items-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50">
                                    <i data-lucide="menu" class="h-5 w-5 text-clinic-700"></i>
                                    Menú
                                </summary>
                                <div class="absolute right-0 mt-3 w-72 rounded-3xl border border-slate-200 bg-white p-3 shadow-soft">
                                    <nav class="space-y-1">
                                        @foreach (var item in navItems)
                                        {
                                            var isActive = item.Match == "/"
                                                ? (currentPath == "/" || currentPath.Equals("/Index", StringComparison.OrdinalIgnoreCase))
                                                : currentPath.StartsWith(item.Match, StringComparison.OrdinalIgnoreCase);

                                            <a asp-page="@item.Page"
                                               class="@(isActive ? "nav-active" : "text-slate-600 hover:bg-slate-100 hover:text-slate-950") flex items-center gap-3 rounded-2xl px-3 py-3 text-sm font-semibold transition">
                                                <i data-lucide="@item.Icon" class="h-5 w-5 text-clinic-700"></i>
                                                <span>@item.Label</span>
                                            </a>
                                        }
                                    </nav>
                                    <form method="post" asp-page="/Auth/Logout" class="mt-2 border-t border-slate-100 pt-2">
                                        <button type="submit" class="inline-flex w-full items-center gap-2 rounded-2xl px-3 py-3 text-left text-sm font-bold text-red-600 transition hover:bg-red-50">
                                            <i data-lucide="log-out" class="h-4 w-4"></i>
                                            Cerrar sesión
                                        </button>
                                    </form>
                                </div>
                            </details>

                            <div class="hidden items-center gap-3 rounded-2xl border border-slate-200 bg-white px-3 py-2 shadow-sm sm:flex">
                                <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-clinic-100 text-sm font-extrabold text-clinic-700">
                                    @inicial
                                </div>
                                <div class="text-right">
                                    <p class="text-sm font-bold text-slate-900">@nombreMostrar</p>
                                    <p class="text-xs text-slate-500">@(string.IsNullOrWhiteSpace(rol) ? "En línea" : rol)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                @if (fullWidth)
                {
                    <main class="w-full page-appear">
                        @RenderBody()
                    </main>
                }
                else
                {
                    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 page-appear">
                        @RenderBody()
                    </main>
                }
            </div>
        </div>
    }
    else
    {
        @if (fullWidth)
        {
            <main class="w-full page-appear">
                @RenderBody()
            </main>
        }
        else
        {
            <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 page-appear">
                @RenderBody()
            </main>
        }
    }

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (window.lucide) {
                window.lucide.createIcons({ attrs: { "stroke-width": 2.2 } });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
